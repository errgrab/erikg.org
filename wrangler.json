{
  "name": "erikg-cloudflare",
  "main": "server/worker.js",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "routes": [
    {
      "pattern": "erikg.org/*",
      "zone_name": "erikg.org"
    },
    {
      "pattern": "*.erikg.org/*",
      "zone_name": "erikg.org"
    }
  ]
}
