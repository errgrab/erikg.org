{
  "name": "erikg-cloudflare",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": ".svelte-kit/cloudflare"
  },
  "routes": [
    {
      "pattern": "erikg.org/*",
      "zone_name": "erikg.org"
    },
    {
      "pattern": "*.erikg.org/*",
      "zone_name": "erikg.org"
    }
  ]
}
