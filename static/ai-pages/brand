        <style>
            :root {
                --bg: #0e0e0c;
                --fg: #f0ede6;
                --dim: #4a4a46;
                --acc: #c07a20;
                --surface: #1a1a18;
                --border: rgba(240, 237, 230, 0.08);
            }
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            body {
                background: var(--bg);
                color: var(--fg);
                font-family: "DM Mono", monospace;
                font-weight: 300;
                padding: 3rem 2rem 6rem;
                max-width: 900px;
                margin: 0 auto;
            }
            .page-header {
                display: flex;
                align-items: center;
                gap: 1rem;
                margin-bottom: 4rem;
                padding-bottom: 2rem;
                border-bottom: 1px solid var(--border);
            }
            .page-header h1 {
                font-size: 13px;
                font-weight: 300;
                letter-spacing: 0.18em;
                color: var(--dim);
                text-transform: uppercase;
            }
            .page-header span {
                color: var(--acc);
            }
            .label {
                font-size: 10px;
                letter-spacing: 0.18em;
                text-transform: uppercase;
                color: var(--dim);
                margin-bottom: 1.2rem;
            }
            section {
                margin-bottom: 4rem;
            }
            .icon-grid {
                display: flex;
                flex-wrap: wrap;
                gap: 1.5rem;
                align-items: flex-end;
            }
            .icon-card {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 0.6rem;
            }
            .icon-card .tag {
                font-size: 9px;
                letter-spacing: 0.1em;
                color: var(--dim);
            }
            .on-dark {
                background: #111110;
                padding: 1.2rem;
                border-radius: 8px;
            }
            .on-light {
                background: #f5f4f0;
                padding: 1.2rem;
                border-radius: 8px;
            }
            .banner-card {
                width: 100%;
                border-radius: 8px;
                overflow: hidden;
                margin-bottom: 1rem;
            }
            .banner-card .tag {
                padding: 5px 10px;
                font-size: 9px;
                letter-spacing: 0.1em;
                color: var(--dim);
                background: var(--surface);
                border-top: 1px solid var(--border);
            }
            hr {
                border: none;
                border-top: 1px solid var(--border);
                margin: 3rem 0;
            }
        </style>
    </head>
